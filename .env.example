# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# Required: FRED API key (free — register at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Required for Lens B commodity data (free — register at https://www.eia.gov/opendata/)
# Note: crude oil (DCOILWTICO) is available via FRED and does NOT need this key.
# EIA key is only needed if pulling EIA directly (Phase 1A can proceed without it).
EIA_API_KEY=your_eia_api_key_here

# Optional: Japan e-Stat app ID (free — register at https://www.e-stat.go.jp/api/en)
# Unlocks live Japanese monthly CPI; without it JP inflation uses an annual IMF
# bridge. Leave blank to skip.
ESTAT_APP_ID=

# Optional: Bank of Korea ECOS key (free — register at https://ecos.bok.or.kr/api/)
# Unlocks live Korean monthly CPI + extra rate series. Leave blank to skip.
BOK_API_KEY=

# Data paths (defaults match the canonical project paths; override only if needed)
DATA_DIR=/mnt/data/project_data/all_weather/indicators_machine
DB_PATH=/mnt/data/db/all_weather/indicators_machine/signals.duckdb
RAW_CACHE_DIR=/mnt/data/project_data/all_weather/indicators_machine/raw_cache
SNAPSHOTS_DIR=/mnt/data/project_data/all_weather/indicators_machine/snapshots

# Optional: timezone for the daily auto-import schedule (Settings → Data updates).
# Use an IANA name, e.g. America/Chicago, America/New_York, Europe/London.
TZ=America/Chicago
